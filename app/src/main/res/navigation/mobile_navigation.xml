<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.syllabuzz.ui.home.HomeFragment"
        android:label="@string/menu_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_subjects"
        android:name="com.example.syllabuzz.SubjectsFragment"
        android:label="@string/menu_subjects"
        tools:layout="@layout/fragment_subjects" >
        <action
            android:id="@+id/action_subjectsFragment_to_chaptersFragment"
            app:destination="@id/chaptersFragment" />
        <action
            android:id="@+id/action_subjectsFragment_to_lessonsFragment"
            app:destination="@id/lessonsFragment" />
    </fragment>

    <fragment
        android:id="@+id/chaptersFragment"
        android:name="com.example.syllabuzz.ui.chapters.ChaptersFragment"
        android:label="Chapters"
        tools:layout="@layout/fragment_list_generic" >
        <argument
            android:name="subjectId"
            app:argType="string" />
        <argument
            android:name="subjectName"
            app:argType="string" />
        <action
            android:id="@+id/action_chaptersFragment_to_topicsFragment"
            app:destination="@id/topicsFragment" />
    </fragment>

    <fragment
        android:id="@+id/topicsFragment"
        android:name="com.example.syllabuzz.ui.topics.TopicsFragment"
        android:label="Topics"
        tools:layout="@layout/fragment_list_generic" >
        <argument
            android:name="chapterId"
            app:argType="string" />
        <argument
            android:name="chapterName"
            app:argType="string" />
        <action
            android:id="@+id/action_topicsFragment_to_quizListFragment"
            app:destination="@id/quizListFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizListFragment"
        android:name="com.example.syllabuzz.ui.quiz.QuizListFragment"
        android:label="Quizzes"
        tools:layout="@layout/fragment_list_generic" >
        <argument
            android:name="topicId"
            app:argType="string" />
        <argument
            android:name="topicName"
            app:argType="string" />
        <action
            android:id="@+id/action_quizListFragment_to_quizFragment"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.example.syllabuzz.ui.quiz.QuizFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz" >
        <argument
            android:name="quizId"
            app:argType="string" />
        <argument
            android:name="quizName"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.syllabuzz.auth.LoginFragment"
        android:label="Sign In"
        tools:layout="@layout/fragment_login" />
    <fragment
        android:id="@+id/lessonsFragment"
        android:name="com.example.syllabuzz.LessonsFragment"
        android:label="fragment_lessons"
        tools:layout="@layout/fragment_lessons" >
        <action
            android:id="@+id/action_lessonsFragment_to_lessonContentFragment"
            app:destination="@id/lessonContentFragment" />
    </fragment>
    <fragment
        android:id="@+id/lessonContentFragment"
        android:name="com.example.syllabuzz.LessonContentFragment"
        android:label="fragment_lesson_content"
        tools:layout="@layout/fragment_lesson_content" />

    <fragment
        android:id="@+id/nav_progress"
        android:name="com.example.syllabuzz.ui.progress.ProgressFragment"
        android:label="@string/menu_progress"
        tools:layout="@layout/fragment_progress_api" />

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.syllabuzz.ui.settings.SettingsFragment"
        android:label="@string/menu_settings"
        tools:layout="@layout/fragment_slideshow" />
</navigation>